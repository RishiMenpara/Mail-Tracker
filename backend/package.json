{
  "name": "mailtrackr-backend",
  "version": "1.0.0",
  "description": "Backend API for MailTrackr email open-tracking system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node -e \"require('./dist/database/migrate').runMigration()\"",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "pg": "^8.11.5",
    "ua-parser-js": "^1.0.38",
    "uuid": "^9.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.5",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
